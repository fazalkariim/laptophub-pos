generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  BRANCH_MANAGER
  ACCOUNTANT
  SALESMAN
}

enum StockStatus {
  IN_STOCK
  SOLD
  IN_TRANSIT
  RESERVED
  RETURNED
}

enum SaleStatus {
  COMPLETED
  RETURNED
  PARTIALLY_RETURNED
}

enum WarrantyStatus {
  ACTIVE
  EXPIRED
  VOID
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum MovementType {
  INTAKE
  SALE
  RETURN
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  BULK_INTAKE
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum TransferStatus {
  IN_TRANSIT
  RECEIVED
  REJECTED
  CANCELLED
}

// ──────────────────────────────────────────────
// TENANT FOUNDATION
// ──────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  plan      String   @default("single")
  status    String   @default("active")
  createdAt DateTime @default(now())

  branches       Branch[]
  users          User[]
  products       Product[]
  stockItems     StockItem[]
  sales          Sale[]
  customers      Customer[]
  warranties     Warranty[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
  stockMovements StockMovement[]
  transfers      Transfer[]
  passwordResetTokens PasswordResetToken[]
  importBatches ImportBatch[]
  auditLogs AuditLog[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  users          User[]
  stockItems     StockItem[]
  sales          Sale[]
  customers      Customer[]
  expenses       Expense[]
  stockMovements StockMovement[]

  @@index([tenantId])
  @@map("branches")
}

model Counter {
  id       String @id @default(uuid())
  tenantId String
  name     String // jaise "invoice"
  value    Int    @default(0)

  @@unique([tenantId, name])
  @@map("counters")
}

// ──────────────────────────────────────────────
// USERS & AUTH
// ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  branchId     String?  // null = Super Admin (head office)
  role         Role
  email        String
  passwordHash String
  refreshTokenHash String?  // logged-in refresh token ka hash 
  name         String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])

  sales          Sale[]
  stockMovements StockMovement[]
  passwordResetTokens PasswordResetToken[]
  importBatches ImportBatch[]
  auditLogs AuditLog[]

  @@unique([tenantId, email]) // email har tenant ke andar unique
  @@index([tenantId])
  @@map("users")
}


model PasswordResetToken {
  id        String    @id @default(uuid())
  tenantId  String
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// ──────────────────────────────────────────────
// CATALOGUE (shared across branches)
// ──────────────────────────────────────────────

model Product {
  id        String   @id @default(uuid())
  tenantId  String
  brand     String
  model     String
  specs     String?
  category  String
  sku       String
  barcode   String?
  createdAt DateTime @default(now())

  deletedAt DateTime?  // soft delete — null = active, date = deleted

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  stockItems StockItem[]
  poLines    POLine[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

// ──────────────────────────────────────────────
// INVENTORY
// ──────────────────────────────────────────────

model StockItem {
  id           String      @id @default(uuid())
  tenantId     String
  branchId     String
  productId    String
  serialNumber String?
  quantity     Int         @default(1)
  status       StockStatus @default(IN_STOCK)
  costPrice    Decimal?    @db.Decimal(12, 2)
  createdAt    DateTime    @default(now())

  // Bulk intake v2 — naye fields
  lastScan         String?
  vendorQuotedCost Decimal?  @db.Decimal(12, 2)
  finalSalePrice   Decimal?  @db.Decimal(12, 2)
  buyer            String?
  transactionDate  DateTime?
  saleAt           String?
  vendorId         String?     // Supplier se link (free text nahi)
  vendorTrackingId String?
  receivedOn       DateTime?

  tenant         Tenant     @relation(fields: [tenantId], references: [id])
  branch         Branch     @relation(fields: [branchId], references: [id])
  product        Product    @relation(fields: [productId], references: [id])
  vendorSupplier Supplier?  @relation(fields: [vendorId], references: [id])
  saleLines      SaleLine[]
  warranties     Warranty[]
  transferLines  TransferLine[] 

  @@unique([tenantId, serialNumber])
  @@index([tenantId, branchId])
  @@index([productId])
  @@map("stock_items")
}

// ──────────────────────────────────────────────
// SALES
// ──────────────────────────────────────────────

model Sale {
  id            String        @id @default(uuid())
  tenantId      String
  branchId      String
  invoiceNumber String        // readable invoice number (jaise INV-2026-0001)
  salesmanId    String
  customerId    String?
  subtotal      Decimal       @db.Decimal(12, 2)  // discount se pehle
  totalDiscount Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)  // final (subtotal - discount)
  amountPaid    Decimal       @default(0) @db.Decimal(12, 2)  // kitna paid hua
  paymentStatus PaymentStatus @default(PAID)
  status        SaleStatus    @default(COMPLETED)
  createdAt     DateTime      @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  branch   Branch    @relation(fields: [branchId], references: [id])
  salesman User      @relation(fields: [salesmanId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  lines    SaleLine[]
  payments Payment[]

  @@unique([tenantId, invoiceNumber])  // invoice number har tenant mein unique
  @@index([tenantId, branchId])
  @@index([createdAt])
  @@map("sales")
}

model SaleLine {
  id          String  @id @default(uuid())
  saleId      String
  stockItemId String?
  productId   String?
  price       Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)

  sale      Sale       @relation(fields: [saleId], references: [id])
  stockItem StockItem? @relation(fields: [stockItemId], references: [id])

  @@index([saleId])
  @@map("sale_lines")
}

model Payment {
  id     String  @id @default(uuid())
  saleId String
  method String  // cash, card, transfer
  amount Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id])

  @@index([saleId])
  @@map("payments")
}

model Transfer {
  id              String         @id @default(uuid())
  tenantId        String
  transferNumber  String         // readable (jaise TRF-2026-0001)
  sourceBranchId  String
  destBranchId    String
  status          TransferStatus @default(IN_TRANSIT)
  sentById        String
  receivedById    String?        // jisne receive/reject kiya
  note            String?
  createdAt       DateTime       @default(now())
  completedAt     DateTime?      // received/rejected/cancelled ka waqt
  metadata Json?

  tenant Tenant         @relation(fields: [tenantId], references: [id])
  lines  TransferLine[]

  @@unique([tenantId, transferNumber])
  @@index([tenantId])
  @@index([sourceBranchId])
  @@index([destBranchId])
  @@map("transfers")
}

model TransferLine {
  id          String @id @default(uuid())
  transferId  String
  stockItemId String

  transfer  Transfer  @relation(fields: [transferId], references: [id])
  stockItem StockItem @relation(fields: [stockItemId], references: [id])  // ← naya

  @@index([transferId])
  @@map("transfer_lines")
}


// ──────────────────────────────────────────────
// CRM & WARRANTY
// ──────────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid())
  tenantId  String
  branchId  String   // creating branch
  name      String
  contact   String?
  type      String?  // individual, business
  tags      String[]
  createdAt DateTime @default(now())

  deletedAt DateTime? // Soft delete

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  sales      Sale[]
  warranties Warranty[]

  @@index([tenantId, branchId])
  @@index([contact])
  @@map("customers")
}

model Warranty {
  id          String         @id @default(uuid())
  tenantId    String
  customerId  String
  stockItemId String?
  serial      String?
  startDate   DateTime
  endDate     DateTime
  status      WarrantyStatus @default(ACTIVE)

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  customer  Customer   @relation(fields: [customerId], references: [id])
  stockItem StockItem? @relation(fields: [stockItemId], references: [id])

  @@index([tenantId])
  @@map("warranties")
}

// ──────────────────────────────────────────────
// PURCHASING
// ──────────────────────────────────────────────

model Supplier {
  id       String  @id @default(uuid())
  tenantId String
  name     String
  contact  String?
  terms    String?

  deletedAt DateTime? // Soft delete

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]
  vendorStockItems StockItem[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id                  String              @id @default(uuid())
  tenantId            String
  poNumber            String              // readable (PO-2026-0001)
  supplierId          String
  destinationBranchId String
  status              PurchaseOrderStatus @default(DRAFT)
  totalCost           Decimal             @default(0) @db.Decimal(12, 2)
  amountPaid          Decimal             @default(0) @db.Decimal(12, 2)
  paymentStatus       PaymentStatus       @default(UNPAID)
  createdById         String
  note                String?
  createdAt           DateTime            @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
  lines    POLine[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model POLine {
  id            String  @id @default(uuid())
  poId          String
  productId     String
  quantity      Int     // kitne order kiye
  receivedQty   Int     @default(0)  // kitne abhi tak receive hue
  costPrice     Decimal @db.Decimal(12, 2)

  po      PurchaseOrder @relation(fields: [poId], references: [id])
  product Product       @relation(fields: [productId], references: [id])

  @@index([poId])
  @@map("po_lines")
}

// ──────────────────────────────────────────────
// FINANCE
// ──────────────────────────────────────────────

model Expense {
  id       String   @id @default(uuid())
  tenantId String
  branchId String
  category String
  amount   Decimal  @db.Decimal(12, 2)
  date     DateTime

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([tenantId, branchId])
  @@map("expenses")
}

// ──────────────────────────────────────────────
// AUDIT / STOCK MOVEMENT (append-only)
// ──────────────────────────────────────────────

model StockMovement {
  id        String       @id @default(uuid())
  tenantId  String
  branchId  String
  userId    String
  type      MovementType
  reason    String?
  stockItemId String?
  metadata  Json?
  timestamp DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  branch Branch @relation(fields: [branchId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, branchId])
  @@index([timestamp])
  @@map("stock_movements")
}

// ──────────────────────────────────────────────
// ImportBatch
// ──────────────────────────────────────────────

model ImportBatch {
  id           String   @id @default(uuid())
  tenantId     String
  uploadedById String
  fileName     String
  uploadedAt   DateTime @default(now())
  totalRows    Int
  successCount Int
  failedCount  Int
  rows         Json

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([tenantId])
  @@map("import_batches")
}

// ──────────────────────────────────────────────
// AuditLog
// ──────────────────────────────────────────────
model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  userName    String?
  userRole    Role
  method      String
  path        String
  action      String
  entityType  String?
  entityId    String?
  statusCode  Int
  requestBody Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, userId])
  @@index([tenantId, entityType])
  @@map("audit_logs")
}